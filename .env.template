# .env.template — copy to .env and fill in. .env MUST stay gitignored.
#
# Every value below is a placeholder the build or runtime reads dynamically.
# The public clone ships with PLACEHOLDER_* strings baked into the fallback
# files (server-config.yaml, *.keystore stubs) so nothing here leaks; setting
# these env vars before building/running is what makes the app actually work.
#
# Precedence wherever a value is read:
#   CLI flag  >  env var  >  server-config.yaml (fallback)  >  placeholder
#
# ─────────────────────────────────────────────────────────────────────────────
# BACKEND / QUEUE ENDPOINT
# Consumed by:
#   androidApp/build.gradle.kts  → baked into BuildConfig.{BACKEND_URL,QUEUE_HOST,QUEUE_PORT}
#   desktopApp/.../Main.kt       → resolveBackendUrl() and resolveQueueConfig()
# Corresponding YAML fallback: {androidApp,desktopApp,desktopApp/src/main/resources}/server-config.yaml
# ─────────────────────────────────────────────────────────────────────────────
BACKEND_URL=http://your-backend.example.com:8080
QUEUE_HOST=your-queue-host.example.com
QUEUE_PORT=9999

# ─────────────────────────────────────────────────────────────────────────────
# ANDROID DEBUG SIGNING
# Consumed by: androidApp/build.gradle.kts → signingConfigs.debug
# The file at ANDROID_DEBUG_KEYSTORE_PATH must be a real JKS/PKCS12 keystore —
# the committed debug-learnlauncher.keystore is a text-note placeholder.
# Generate one with:
#   keytool -genkeypair -v -keystore debug-learnlauncher.keystore \
#     -alias learnlauncher -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass "$ANDROID_DEBUG_STORE_PASSWORD" \
#     -keypass  "$ANDROID_DEBUG_KEY_PASSWORD" \
#     -dname    "CN=learnlauncher-debug"
# ─────────────────────────────────────────────────────────────────────────────
ANDROID_DEBUG_KEYSTORE_PATH=debug-learnlauncher.keystore
ANDROID_DEBUG_STORE_PASSWORD=change-me-debug-store
ANDROID_DEBUG_KEY_ALIAS=learnlauncher
ANDROID_DEBUG_KEY_PASSWORD=change-me-debug-key

# ─────────────────────────────────────────────────────────────────────────────
# ANDROID RELEASE SIGNING
# Consumed by: androidApp/build.gradle.kts → signingConfigs.release
# Same caveat as debug. Generate with:
#   keytool -genkeypair -v -keystore release-learnlauncher.keystore \
#     -alias learnlauncher_release -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass "$ANDROID_RELEASE_STORE_PASSWORD" \
#     -keypass  "$ANDROID_RELEASE_KEY_PASSWORD" \
#     -dname    "CN=learnlauncher-release"
# ─────────────────────────────────────────────────────────────────────────────
ANDROID_RELEASE_KEYSTORE_PATH=release-learnlauncher.keystore
ANDROID_RELEASE_STORE_PASSWORD=change-me-release-store
ANDROID_RELEASE_KEY_ALIAS=learnlauncher_release
ANDROID_RELEASE_KEY_PASSWORD=change-me-release-key

# ─────────────────────────────────────────────────────────────────────────────
