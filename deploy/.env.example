# tcpc-targeted APK build config — copy to deploy/.env, fill in.
#
#   cp deploy/.env.example deploy/.env && chmod 600 deploy/.env
#
# build-apk.sh sources this, materializes server-config.yaml, exports the
# env vars the env-aware build.gradle.kts already reads, and runs gradle.

# ── Where the APK should send sync data ────────────────────────
# These map onto BuildConfig.{BACKEND_URL,QUEUE_HOST,QUEUE_PORT} which the
# Android source already reads. tcpc's archive receiver listens on
# TCPC_ARCHIVE_PORT — once the Kotlin SyncService is ported (option b in
# the design notes) it will dial QUEUE_HOST:QUEUE_PORT directly.
#
# Today the Android code still HTTP-POSTs to BACKEND_URL/sync/upload, so
# BACKEND_URL still needs to be a host that speaks that legacy endpoint
# (or stays as a placeholder until the Kotlin side is rewritten).
BACKEND_URL=http://<tcpc-host>:8080
QUEUE_HOST=<tcpc-host>
QUEUE_PORT=51521              # TCPC_PORT from i:/_tcp-comm/deploy/client.env

# Future tcpc-direct fields (not yet wired in Kotlin — option b will read these):
TCPC_ARCHIVE_HOST=<tcpc-host>
TCPC_ARCHIVE_PORT=51537
TCPC_ADMIN_TOKEN=<from i:/_tcp-comm/deploy/client.env>

# ── Android signing ────────────────────────────────────────────
# Keystores are .keystore / .jks files. NEVER commit them.
# Keep them in deploy/ (gitignored) or out-of-tree.
ANDROID_RELEASE_KEYSTORE_PATH=deploy/release-learnlauncher.keystore
ANDROID_RELEASE_STORE_PASSWORD=
ANDROID_RELEASE_KEY_ALIAS=learnlauncher_release
ANDROID_RELEASE_KEY_PASSWORD=

ANDROID_DEBUG_KEYSTORE_PATH=deploy/debug-learnlauncher.keystore
ANDROID_DEBUG_STORE_PASSWORD=android
ANDROID_DEBUG_KEY_ALIAS=learnlauncher
ANDROID_DEBUG_KEY_PASSWORD=android

# ── Build output ───────────────────────────────────────────────
# Where build-apk.sh copies the final APK after gradle finishes.
APK_OUT_DIR=./build/apks
